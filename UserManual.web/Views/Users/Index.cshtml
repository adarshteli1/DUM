@model IEnumerable<UserManual.Application.DTOs.UserDto>

@{
    ViewData["Title"] = "User Management";
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-12">

            <h3 class="fw-semibold mb-3">👥 All Users</h3>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="d-flex justify-content-end mb-3">
                <a class="btn btn-primary fw-semibold" asp-action="CreateUser">+ Add New User</a>
            </div>

            <div class="table-responsive shadow-sm border rounded-4">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-primary text-center">
                        <tr>
                            <th>User ID</th>
                            <th>Username</th>
                            <th>Role</th>
                            <th>Department</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr class="text-center">
                                <td>@user.UserId</td>
                                <td>@user.UserName</td>
                                <td>
                                    <span class="badge bg-secondary">@user.AccessRole</span>
                                </td>
                                <td>@user.DepartmentName</td>
                                <td>
                                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@user.UserId">
                                        🗑 Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>
