@model IEnumerable<UserManual.Application.DTOs.AuditLogDto>

@{
    ViewData["Title"] = "Audit Logs";
}

<h2>Audit Logs</h2>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr>
            <th>User ID</th>
            <th>Entity ID</th>
            <th>Action</th>
            <th>Timestamp</th>
            <th>Details</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model)
        {
            <tr>
                <td>@log.UserId</td>
                <td>@log.EntityId</td>
                <td>@log.ActionType</td>
                <td>@log.ActionTimestamp.ToString("g")</td>
                <td>@log.Details</td>
            </tr>
        }
    </tbody>
</table>
