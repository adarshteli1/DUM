@model UserManual.Application.DTOs.TaskItemDto
@using UserManual.Application.DTOs
@{
    ViewData["Title"] = "Create Task";
    var users = ViewBag.Users as List<UserDto> ?? new List<UserDto>();
    var dashboardUrl = ViewBag.UserRole == "Admin"
        ? Url.Action("Dashboard", "Admin")
        : Url.Action("Dashboard", "Manuals");
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm rounded-4 border-0 p-4">
                <h3 class="fw-semibold mb-4">📝 Create New Task</h3>

                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label asp-for="TaskItemName" class="form-label">Task Name</label>
                        <input asp-for="TaskItemName" class="form-control" />
                        <span asp-validation-for="TaskItemName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Status" class="form-label">Status</label>
                        <input asp-for="Status" class="form-control" placeholder="Upcoming / Completed / Overdue" />
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DueDate" class="form-label">Due Date</label>
                        <input asp-for="DueDate" class="form-control" type="date" />
                        <span asp-validation-for="DueDate" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UserId" class="form-label">Assign to User</label>
                        @if (users.Any())
                        {
                            <select asp-for="UserId" class="form-select">
                                <option value="">-- Select User --</option>
                                @foreach (var user in users)
                                {
                                    <option value="@user.UserId">@user.UserName - @user.Email</option>
                                }
                            </select>
                        }
                        else
                        {
                            <div class="alert alert-warning small">
                                ⚠️ No users available. Please <a asp-controller="Users" asp-action="CreateUser">add a user</a> first.
                            </div>
                        }
                        <span asp-validation-for="UserId" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="@dashboardUrl" class="btn btn-secondary">← Cancel</a>
                        <button type="submit" class="btn btn-success">✅ Create Task</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}


