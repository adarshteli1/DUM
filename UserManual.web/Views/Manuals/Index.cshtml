@model IEnumerable<UserManual.Application.DTOs.ManualDto>

@{
    ViewData["Title"] = "Manuals";
}

<h2>User Manuals</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">+ Upload New Manual</a>
</p>

<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>Manual ID</th>
            <th>File Name</th>
            <th>File Path</th>
            <th>Upload Date</th>
            <th>Task ID</th>
            <th>User ID</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var manual in Model)
        {
            <tr>
                <td>@manual.ManualId</td>
                <td>@manual.FileName</td>
                <td>@manual.FilePath</td>
                <td>@manual.UploadDate.ToShortDateString()</td>
                <td>@manual.TaskItemId</td>
                <td>@manual.UserId</td>
                <td>
                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@manual.ManualId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
@*
